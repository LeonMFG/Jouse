# Copy this file to ".env" and fill in real values for production.
# (Most hosts let you set these as "environment variables" in their dashboard instead of a file.)

# REQUIRED in production: a long random secret used to sign login sessions.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Tells the app to use secure (HTTPS-only) cookies and other production behavior.
NODE_ENV=production

# Port the server listens on (most hosts set this for you automatically).
PORT=3000

# Where the database + uploaded files are stored. In production point these at a
# mounted persistent disk so data survives restarts/redeploys.
DATA_DIR=./data
UPLOAD_DIR=./uploads
